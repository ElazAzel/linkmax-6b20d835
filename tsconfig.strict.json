{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "strictNullChecks": true,
        "noImplicitAny": true
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/vite-env.d.ts"
    ],
    "exclude": [
        "src/**/__tests__/**",
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/testing/**"
    ]
}