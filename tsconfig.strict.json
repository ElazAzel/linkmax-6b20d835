{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "strictNullChecks": true,
        "noImplicitAny": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": false,
        "noPropertyAccessFromIndexSignature": false,
        "noUnusedLocals": true,
        "noUnusedParameters": true
    },
    "include": [
        "src/lib/**/*",
        "src/domain/**/*",
        "src/use-cases/**/*",
        "src/repositories/**/*",
        "src/services/**/*",
        "src/types/**/*",
        "src/vite-env.d.ts"
    ]
}