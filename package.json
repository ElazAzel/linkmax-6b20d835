{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "3.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "start": "vite preview",
    "lint": "eslint .",
    "lint:i18n": "LINT_I18N=true eslint . --ext .ts,.tsx",
    "analyze:deps": "depcruise --config config/dependency-cruiser.cjs --output-type text src",
    "analyze:cycles": "depcruise --config config/dependency-cruiser.cjs --output-type err src",
    "analyze:layers": "depcruise --config config/dependency-cruiser.cjs --output-type err src",
    "analyze:unused": "knip --config config/knip.config.ts",
    "quality:gate": "npm run analyze:cycles && npm run analyze:layers && npm run analyze:unused",
    "quality:check": "npm run lint && npm run lint:i18n && npm run i18n:check && npm run typecheck:strict && npm run quality:gate",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --reporter=line",
    "preview": "vite preview",
    "i18n:status": "node scripts/i18n-manager.mjs status",
    "i18n:sync": "node scripts/i18n-manager.mjs sync",
    "i18n:prep": "node scripts/i18n-manager.mjs prep",
    "i18n:merge": "node scripts/i18n-manager.mjs merge",
    "i18n:check": "node scripts/i18n-manager.mjs check",
    "i18n:fill": "node scripts/sync-locales-fill-missing.mjs",
    "i18n:check-coverage": "node scripts/check-locale-coverage.mjs",
    "i18n:audit": "node scripts/audit-locales.mjs",
    "i18n:translate-stubs": "node scripts/translate-stubs-from-en.mjs",
    "i18n:translate-stubs:batch": "node scripts/translate-stubs-from-en.mjs --rounds=18 --max=400 --delay=42",
    "i18n:export": "node scripts/i18n-export.mjs",
    "i18n:import": "node scripts/i18n-import.mjs",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "skills:browse": "ai-agent-skills",
    "skills:list": "ai-agent-skills list",
    "skills:doctor": "ai-agent-skills doctor",
    "quality:baseline": "node scripts/quality-baseline-check.mjs"
  },
